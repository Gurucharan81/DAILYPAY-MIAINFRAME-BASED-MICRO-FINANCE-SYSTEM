*----------------------------------------------------------------*
        DFHMDF POS=(20,5),LENGTH=27,                                   X
               INITIAL='Approval Threshold Score  :',ATTRB=PROT
APPSCR  DFHMDF POS=(20,34),LENGTH=3,ATTRB=UNPROT,HILIGHT=UNDERLINE
        DFHMDF POS=(20,38),LENGTH=1,ATTRB=ASKIP
