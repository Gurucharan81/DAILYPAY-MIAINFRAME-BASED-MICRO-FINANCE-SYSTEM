* FUNCTION KEYS
*----------------------------------------------------------------*
        DFHMDF POS=(23,20),LENGTH=10,INITIAL='PF3=EXIT',ATTRB=PROT
        DFHMDF POS=(23,35),LENGTH=07,INITIAL='ENTER=',ATTRB=PROT
