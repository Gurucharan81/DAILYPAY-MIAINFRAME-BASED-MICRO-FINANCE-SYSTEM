* INTEREST CONFIG
*----------------------------------------------------------------*

        DFHMDF POS=(14,5),LENGTH=28,                                   X
               INITIAL='Interest Rate (%)         :',ATTRB=PROT
INTRATE DFHMDF POS=(14,34),LENGTH=2,ATTRB=UNPROT,HILIGHT=UNDERLINE
        DFHMDF POS=(14,37),LENGTH=1,ATTRB=ASKIP
*----------------------------------------------------------------*
* GRACE PERIOD
*----------------------------------------------------------------*

        DFHMDF POS=(16,5),LENGTH=27,                                   X
               INITIAL='Grace Period (Days)       :',ATTRB=PROT
GRACE   DFHMDF POS=(16,34),LENGTH=1,ATTRB=UNPROT,HILIGHT=UNDERLINE
        DFHMDF POS=(16,36),LENGTH=1,ATTRB=ASKIP
