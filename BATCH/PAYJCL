//OUT1     DD DSN=ADCDA.DPAY.WTRANSFL.TEMP,DISP=SHR
//SYSIN    DD *
  REPRO INFILE(IN1) OUTFILE(OUT1)
/*
//* KSD TO PS (TODAY TRANS TO PS)
//STEP3    EXEC PGM=IDCAMS
//SYSOUT   DD SYSOUT=*
//SYSPRINT DD SYSOUT=*
//IN1      DD DSN=ADCD.DPAY.TODPAY,DISP=SHR
//OUT1     DD DSN=ADCD.DPAY.TODPAY.PSTEMP,DISP=SHR
//SYSIN    DD *
  REPRO INFILE(IN1) OUTFILE(OUT1)
/*
//* TODAY REPORT (TODAY TRANS TO GDG)
//STEP3A   EXEC PGM=SORT
//SYSOUT   DD SYSOUT=*
//SORTIN   DD DSN=ADCD.DPAY.TODPAY.PSTEMP,DISP=SHR
//SORTOUT  DD DSN=ADCD.DPAY.TODPAY.GDG(+1),
//            DISP=(NEW,CATLG,DELETE),
//            SPACE=(CYL,(5,5)),
//            DCB=(RECFM=FBA,LRECL=81)
//SYSIN    DD *
  OPTION COPY
  OUTFIL HEADER1=('TRANSID  LOANID  CUSTID  NAME  ',
                   'STATUS   ACTAMT  PAID    PTYPE      '),
           BUILD=(1,80)
/*
//* TODAY TO MERGE FILE
//STEP4    EXEC PGM=SORT
//SYSPRINT DD SYSOUT=*
//SYSOUT DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SORTIN   DD DSN=ADCD.DPAY.TODPAY,DISP=SHR
//SORTOUT  DD DSN=ADCDA.DPAY.TODPAY.MERGE,DISP=SHR
//SYSIN    DD *
  OPTION COPY
  OUTREC BUILD=(1,53,55,26)
/*
//* MERGE ( WHOLE , TODAY ) TO FINAL
//STEP5    EXEC PGM=SORT
//SYSPRINT DD SYSOUT=*
//SYSOUT   DD SYSOUT=*
//SORTIN01 DD DSN=ADCDA.DPAY.WTRANSFL.TEMP,DISP=SHR
//SORTIN02 DD DSN=ADCDA.DPAY.TODPAY.MERGE,DISP=SHR
//SORTOUT  DD DSN=ADCDA.DPAY.WTRANSFL.FINAL,DISP=SHR
//SYSIN    DD *
  MERGE FIELDS=(1,6,ZD,A)
/*
//* DELETE WHOLE KSDS AND CREATE SAME KSDS
//STEP6 EXEC PGM=IDCAMS
//SYSPRINT DD SYSOUT=*
//SYSIN DD *
   DELETE ADCD.DPAY.WTRANSFL CLUSTER PURGE
   IF MAXCC = 8 THEN SET MAXCC = 0
   DEFINE CLUSTER(NAME(ADCD.DPAY.WTRANSFL)-
      INDEXED-
      CONTROLINTERVALSIZE(2000) -
      KEYS(11 0)-
      VOLUME(USR001)-
      RECORDSIZE(80 80) -
      CYLINDERS(5 5)-
      FREESPACE(10 10))
/*
//* LOAD WHOLE FINAL PS TO WHOLE KSDS
//STEP7    EXEC PGM=IDCAMS
//SYSPRINT DD SYSOUT=*
//IN1      DD DSN=ADCDA.DPAY.WTRANSFL.FINAL,DISP=SHR
//OUT1     DD DSN=ADCD.DPAY.WTRANSFL,DISP=SHR
//SYSIN    DD *
  REPRO INFILE(IN1) OUTFILE(OUT1)
