*----------------------------------------------------------------*
        DFHMDF POS=(24,5),LENGTH=5,INITIAL='MSG :',ATTRB=PROT
MSGFLD  DFHMDF POS=(24,12),LENGTH=60,ATTRB=PROT


        DFHMSD TYPE=FINAL
        END
