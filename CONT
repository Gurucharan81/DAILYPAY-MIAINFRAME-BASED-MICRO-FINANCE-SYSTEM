        DFHMDF POS=(11,5),LENGTH=18,                                   X
               INITIAL='Min Tenure (D)   :',ATTRB=PROT
MINTEN  DFHMDF POS=(11,25),LENGTH=2,ATTRB=UNPROT,HILIGHT=UNDERLINE
        DFHMDF POS=(11,28),LENGTH=1,ATTRB=ASKIP
        DFHMDF POS=(11,45),LENGTH=18,                                  X
               INITIAL='Max Tenure (D)   :',ATTRB=PROT
