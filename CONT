* REAPPLICATION + SCORE
*----------------------------------------------------------------*
        DFHMDF POS=(18,5),LENGTH=28,                                   X
               INITIAL='Reapplication Restriction :',ATTRB=PROT
REAPP   DFHMDF POS=(18,34),LENGTH=3,ATTRB=UNPROT,HILIGHT=UNDERLINE
